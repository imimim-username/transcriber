# ── HuggingFace authentication ────────────────────────────────────────────────
# Required on first run to download the pyannote diarization model.
# Create a token at https://huggingface.co/settings/tokens
# Not needed after the model is cached locally (set HF_HUB_OFFLINE=1 below).
HF_TOKEN=

# ── Offline mode ──────────────────────────────────────────────────────────────
# Set to 1 after models have been downloaded to prevent any network calls.
# Both models (pyannote + Whisper) will load entirely from local cache.
# Default: 0 (online — models are downloaded automatically on first run)
HF_HUB_OFFLINE=0

# ── Cache location ────────────────────────────────────────────────────────────
# By default models are cached in ~/.cache/huggingface (~2 GB total).
# Uncomment and set this if you want to store them elsewhere (e.g. a larger disk).
# HF_HOME=/mnt/data/huggingface
